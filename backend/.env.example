# Copy to .env and fill in your values.
# Production is served by nginx on :80 with the backend on 127.0.0.1:3010.
# Development should use a separate DB path and port such as 3111.

APP_ENV=development
HOST=0.0.0.0
PORT=3111
DB_PATH=/mnt/ssd/dev-data/mortgage-backed/game.db
JWT_SECRET=change-me-to-a-random-secret-string
JWT_EXPIRY=30d
CORS_ORIGINS=http://100.110.102.49:3011,http://pi.taildb6607.ts.net:3011,http://localhost:3011
REQUEST_BODY_LIMIT=256kb
ALLOW_STATE_REPAIR=false
LOG_OTPS=true

# Production example:
# APP_ENV=production
# HOST=127.0.0.1
# PORT=3010
# DB_PATH=/mnt/ssd/projects/mortgage-backed/backend/game.db
# JWT_SECRET=<long-random-secret>
# JWT_EXPIRY=12h
# CORS_ORIGINS=https://mortgage.abdlh.com,http://mortgage.abdlh.com
# LOG_OTPS=false

# UseSend email API config. If not set, send attempts are best-effort and fail closed in production logs.
USESEND_API_KEY=
USESEND_URL=http://127.0.0.1:3001/api/v1/emails
SMTP_FROM=noreply@mortgage.abdlh.com
